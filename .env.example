# Chatwoot self-hosted URL without a trailing slash
CHATWOOT_BASE_URL=https://chat.engosoft.com

# Create a fresh token from Chatwoot Profile Settings.
# Do not commit the real token to GitHub.
CHATWOOT_API_TOKEN=replace_me

# Your Chatwoot account id
CHATWOOT_ACCOUNT_ID=2

# Required when creating new contacts through the Chatwoot Application API.
# Open a Chatwoot inbox URL and copy the inbox id, or fetch it from the inboxes API.
CHATWOOT_INBOX_ID=replace_me

# Optional, useful for Saudi numbers like 0500000000 or 9660500000000.
DEFAULT_COUNTRY_CODE=966

# Optional simple guard for the importer page/API.
# Recommended when the app is publicly reachable.
APP_PASSWORD=change_me

# Server port used by Coolify/Docker
PORT=3000

# Delay between Chatwoot API operations to be gentle with self-hosted instances.
REQUEST_DELAY_MS=350
